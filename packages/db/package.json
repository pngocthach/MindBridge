{
	"name": "@MindBridge/db",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"check-types": "tsc --noEmit",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "pnpm exec tsx --env-file=../../apps/server/.env src/seed.ts",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@MindBridge/env": "workspace:*",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.2",
		"pg": "^8.22.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@MindBridge/config": "workspace:*",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.23.1",
		"typescript": "catalog:"
	}
}
