# Set both values to the production domain. Caddy provisions HTTPS automatically.
PUBLIC_ORIGIN=https://mindbridge.lol
CADDY_SITE=mindbridge.lol

POSTGRES_DB=mindbridge
POSTGRES_USER=mindbridge
POSTGRES_PASSWORD=replace-with-a-long-unique-password
DATABASE_URL=postgres://mindbridge:replace-with-a-long-unique-password@postgres:5432/mindbridge

# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=https://mindbridge.lol
CORS_ORIGIN=https://mindbridge.lol
NODE_ENV=production

# Optional OpenAI-compatible tutor backend.
TUTOR_LLM_BASE_URL=
TUTOR_LLM_MODEL=
TUTOR_LLM_API_KEY=

# Optional content-generation backend. These take precedence over TUTOR_LLM_*.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_API_KEY=
