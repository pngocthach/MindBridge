# Copy to apps/server/.env for local development. Never commit real values.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/mindbridge
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
NODE_ENV=development

# Optional OpenAI-compatible tutor backend (9Router, OpenRouter, etc.).
TUTOR_LLM_BASE_URL=https://provider.example.com/v1
TUTOR_LLM_MODEL=provider/model-name
TUTOR_LLM_API_KEY=replace-with-provider-secret

# Optional content-generation backend.
OPENAI_COMPATIBLE_BASE_URL=https://provider.example.com/v1
OPENAI_COMPATIBLE_MODEL=provider/model-name
OPENAI_COMPATIBLE_API_KEY=replace-with-provider-secret
