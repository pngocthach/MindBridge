{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"baml:generate": "baml generate",
		"build": "pnpm baml:generate && tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.mjs"
	},
	"dependencies": {
		"@MindBridge/api": "workspace:*",
		"@MindBridge/auth": "workspace:*",
		"@MindBridge/db": "workspace:*",
		"@MindBridge/env": "workspace:*",
		"@boundaryml/baml": "0.223.0",
		"@hono/node-server": "^2.0.8",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.2",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@MindBridge/config": "workspace:*",
		"@types/node": "catalog:",
		"tsdown": "^0.22.3",
		"tsx": "^4.22.5",
		"typescript": "catalog:"
	}
}
